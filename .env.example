# CatchFade Environment Configuration
# Copy this to .env and fill in your values
# Usage: source .env  OR  python-dotenv will load automatically

# ─── Node Configuration ────────────────────────────────────────────
CF_NODE_ID=CF-NODE-COASTAL-01
CF_SIMULATED=true              # Set to false for real hardware

# ─── Sensing ───────────────────────────────────────────────────────
CF_SENSE_INTERVAL=30           # Seconds between readings
CF_BRIEFING_INTERVAL=10        # Generate briefing every N readings

# ─── LLM Provider ─────────────────────────────────────────────────
# Options: mock | anthropic | openai | ollama
CF_LLM_PROVIDER=mock

# Anthropic (if using Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CF_LLM_MODEL=claude-sonnet-4-20250514

# OpenAI (if using GPT)
# OPENAI_API_KEY=your_openai_api_key_here

# Ollama (if using local LLM)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─── Storage ───────────────────────────────────────────────────────
CF_DB_PATH=catchfade_data.db

# ─── Alerts ────────────────────────────────────────────────────────
CF_ALERT_THRESHOLD=WARNING     # NORMAL | WARNING | CRITICAL | EMERGENCY
CF_SCARCITY_THRESHOLD=0.5      # 0.0 - 1.0
